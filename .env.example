# Financial Datasets API Key (paid backend)
# Get your key at: https://financialdatasets.ai
# Free data available for: AAPL, GOOGL, MSFT, NVDA, TSLA
FINANCIAL_DATASETS_API_KEY=your-api-key-here

# Free backend toggle (no paid API required)
# Set to 1 to route src/tools/api.py through SEC EDGAR + yfinance + OpenInsider.
# See docs/USER_GUIDE.md for the full enable/disable flow.
USE_FREE_BACKEND=0

# Required when USE_FREE_BACKEND=1: SEC EDGAR mandates a contact UA on every request.
# Format: "Your Name your-email@example.com"
SEC_EDGAR_USER_AGENT=
